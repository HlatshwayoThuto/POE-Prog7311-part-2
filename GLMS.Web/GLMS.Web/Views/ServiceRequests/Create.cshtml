@model GLMS.Web.Models.ServiceRequest
@{
    ViewData["Title"] = "New Service Request";
}

<h2>🔧 New Service Request</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="ContractId" class="form-label">Contract (Active only)</label>
                <select asp-for="ContractId" class="form-select" asp-items="ViewBag.Contracts">
                    <option value="">-- Select Contract --</option>
                </select>
                <span asp-validation-for="ContractId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Cost (USD)</label>
                <input type="number"
                       id="costUsd"
                       name="CostUsd"
                       class="form-control"
                       step="0.01"
                       min="0.01"
                       oninput="convertCurrency()" />
                <span class="text-danger" data-valmsg-for="CostUsd"></span>
                <div id="zarPreview" class="mt-2 text-success fw-bold"></div>
                <input type="hidden" id="rateField" value="@ViewBag.ExchangeRate.ToString()" />
            </div>

            <button type="submit" class="btn btn-warning">Submit Request</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function convertCurrency() {
            const usd = parseFloat(document.getElementById('costUsd').value) || 0;
            const rate = parseFloat(document.getElementById('rateField').value) || 18.5;
            document.getElementById('zarPreview').textContent =
                `≈ R${(usd * rate).toFixed(2)} ZAR (Rate: ${rate})`;
        }
    </script>
}