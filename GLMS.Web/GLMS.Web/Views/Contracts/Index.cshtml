@model IEnumerable<GLMS.Web.Models.Contract>
@using GLMS.Web.Models
@{
    ViewData["Title"] = "Contracts";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📄 Contracts</h2>
    <a asp-action="Create" class="btn btn-success">+ New Contract</a>
</div>

<form method="get" class="row g-3 mb-4 p-3 bg-light rounded shadow-sm">
    <div class="col-md-3">
        <label class="form-label">Start Date From</label>
        <input type="date" name="startDate" value="@ViewBag.StartDate" class="form-control" />
    </div>
    <div class="col-md-3">
        <label class="form-label">End Date To</label>
        <input type="date" name="endDate" value="@ViewBag.EndDate" class="form-control" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Status</label>
        <select name="status" class="form-select">
            <option value="">All Statuses</option>
            @foreach (var s in Enum.GetValues<ContractStatus>())
            {
                <option value="@s" selected="@(ViewBag.Status?.ToString() == s.ToString())">@s</option>
            }
        </select>
    </div>
    <div class="col-md-3 d-flex align-items-end gap-2">
        <button type="submit" class="btn btn-primary">Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

<table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>Client</th>
            <th>Start</th>
            <th>End</th>
            <th>Status</th>
            <th>Service Level</th>
            <th>Agreement</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Title</td>
                <td>@c.Client?.Name</td>
                <td>@c.StartDate.ToString("dd MMM yyyy")</td>
                <td>@c.EndDate.ToString("dd MMM yyyy")</td>
                <td>
                    <span class="badge @(c.Status == ContractStatus.Active ? "bg-success" :
                                                                   c.Status == ContractStatus.Expired ? "bg-danger" :
                                                                   c.Status == ContractStatus.OnHold ? "bg-warning text-dark" : "bg-secondary")">
                        @c.Status
                    </span>
                </td>
                <td>@c.ServiceLevel</td>
                <td>
                    @if (c.SignedAgreementPath != null)
                    {
                        <a asp-action="DownloadAgreement" asp-route-id="@c.Id" class="btn btn-sm btn-outline-info">📥 Download</a>
                    }
                    else
                    {
                        <span class="text-muted">None</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>